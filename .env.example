# Required for Telegram Bot
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"
TELEGRAM_CLIENT_SECRET="your_telegram_client_secret_here"
ADMIN_TELEGRAM_ID="your_telegram_id"

# Required for Web App
PUBLIC_URL="https://your-domain.com"

# Required for MongoDB Database
MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority"

# Optional: Redis URL for caching Models, Search Results, and Rate Limiting
# E.g., redis://username:password@redis.host.com:6379 
# If not provided, the app will fall back to in-memory caching.
REDIS_URL=""
